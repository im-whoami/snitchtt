<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@color/surface_dark">

    <!-- Severity dot -->
    <View
        android:id="@+id/viewDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/circle"
        app:layout_constraintTop_toTopOf="@id/tvFlagName"
        app:layout_constraintBottom_toBottomOf="@id/tvFlagName"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Flag name -->
    <TextView
        android:id="@+id/tvFlagName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:fontFamily="monospace"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/viewDot"
        app:layout_constraintEnd_toStartOf="@id/tvFlagScore" />

    <!-- Score badge -->
    <TextView
        android:id="@+id/tvFlagScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/severity_high"
        app:layout_constraintTop_toTopOf="@id/tvFlagName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBaseline_toBaselineOf="@id/tvFlagName" />

    <!-- Description -->
    <TextView
        android:id="@+id/tvFlagDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:maxLines="2"
        app:layout_constraintTop_toBottomOf="@id/tvFlagName"
        app:layout_constraintStart_toEndOf="@id/viewDot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
